# =============================================================================
# Zoom App credentials (from your Zoom Marketplace dev account)
# =============================================================================
# Get these from https://marketplace.zoom.us/develop/create
# After creating a "General App" in development mode.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# Must match the redirect URL configured in the Zoom app
ZOOM_REDIRECT_URI=https://your-domain.vercel.app/api/oauth/callback

# =============================================================================
# Database (Postgres)
# =============================================================================
# Use Neon (https://neon.tech) or Supabase free tier for fastest setup.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# =============================================================================
# Token encryption
# =============================================================================
# 32-byte key, base64 encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# WARNING: This is MVP-grade. Before going public, swap to AWS KMS envelope
# encryption per the spec section 4.9.
TOKEN_ENCRYPTION_KEY=

# =============================================================================
# App config
# =============================================================================
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
